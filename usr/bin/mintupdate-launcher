#!/usr/bin/python3
import os
import subprocess

import xapp.os

if __name__ == "__main__":
    if os.getuid() == 0:
        print("Error: Do not run this as root")
        exit(1)

    if ((not xapp.os.is_live_session()) and (not xapp.os.is_guest_session())):
        subprocess.Popen(["/usr/lib/linuxmint/mintUpdate/mintUpdate.py"])
